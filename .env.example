# ===================
# Application
# ===================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# Database
# ===================
# Note: Using port 5433 to avoid conflicts with local PostgreSQL
DB_PASSWORD=playpatch_dev
DATABASE_URL=postgresql://playpatch:playpatch_dev@localhost:5433/playpatch

# ===================
# Redis
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# Storage
# ===================
# Storage backend: 'local' for filesystem, 'minio' for MinIO/S3
STORAGE_TYPE=local

# Local filesystem storage path (used when STORAGE_TYPE=local)
# Can be local (./storage) or network location (/Volumes/NAS/Media/PlayPatch)
LOCAL_STORAGE_PATH=./storage

# MinIO / S3 Storage (used when STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_AVATARS=avatars

# For production S3 (uncomment and configure):
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your_aws_access_key
# S3_SECRET_KEY=your_aws_secret_key

# ===================
# Meilisearch
# ===================
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=master_key_change_me

# ===================
# AI / LLM
# ===================
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (alternative to Ollama)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ===================
# Authentication
# ===================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_this_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ===================
# Email (Optional - for weekly digests)
# ===================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=PlayPatch <noreply@yourdomain.com>

# ===================
# Production Only
# ===================
DOMAIN=playpatch.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# ===================
# Feature Flags
# ===================
ENABLE_AI=true
ENABLE_TRANSCRIPTION=true
ENABLE_WEEKLY_DIGEST=false

# ===================
# Media Processing
# ===================
WHISPER_MODEL=base
MAX_VIDEO_SIZE_MB=500
TRANSCODE_QUALITY=720p

# ===================
# Content Sources
# ===================
# RealDebrid API for torrent/magnet link downloads
# Get your API token from: https://real-debrid.com/apitoken
REALDEBRID_API_KEY=your_realdebrid_api_key_here

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# RealDebrid Streaming Mode (Stremio-style)
REALDEBRID_STREAM_MODE=true
REALDEBRID_ALLOW_DOWNLOAD=true
